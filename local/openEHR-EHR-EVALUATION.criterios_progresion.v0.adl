definition
	EVALUATION[at0000] matches {    -- Criterios_Progresion
		data matches {
			ITEM_TREE[at0001] matches {    -- Item tree
				items cardinality matches {0..*; unordered} matches {
					ELEMENT[at0002] matches {    -- Fase_actual
						value matches {
							DV_CODED_TEXT matches {
								defining_code matches {
									[local::
									at0003,    -- Fase 1
									at0004,    -- Fase 2
									at0005]    -- Fase 3
								}
							}
						}
					}
					CLUSTER[at0020] occurrences matches {0..1} matches {    -- Criterios cumplidos
						items cardinality matches {1..*; unordered} matches {
							ELEMENT[at0009] matches {    -- EVA < 5
								value matches {
									DV_BOOLEAN matches {*}
								}
							}
							ELEMENT[at0010] matches {    -- Extensión_completa
								value matches {
									DV_BOOLEAN matches {*}
								}
							}
							ELEMENT[at0011] matches {    -- Flexión_suficiente
								value matches {
									DV_BOOLEAN matches {*}
								}
							}
							ELEMENT[at0012] matches {    -- Fuerza >70%
								value matches {
									DV_BOOLEAN matches {*}
								}
							}
							ELEMENT[at0013] matches {    -- Ausencia_inflamación
								value matches {
									DV_BOOLEAN matches {*}
								}
							}
						}
					}
				}
			}
		}
		protocol matches {
			ITEM_TREE[at0014] matches {    -- Item tree
				items cardinality matches {0..*; unordered} matches {
					ELEMENT[at0015] matches {    -- Decisión_clínica
						value matches {
							DV_CODED_TEXT matches {
								defining_code matches {
									[local::
									at0016,    -- Avanzar de fase
									at0017,    -- Mantener fase
									at0018]    -- Modificar protocolo
								}
							}
						}
					}
					ELEMENT[at0019] occurrences matches {0..1} matches {    -- Observaciones
						value matches {
							DV_TEXT matches {*}
						}
					}
				}
			}
		}
	}

