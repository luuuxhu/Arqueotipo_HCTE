definition
	CLUSTER[at0000] matches {    -- Datos del paciente
		items cardinality matches {1..*; unordered} matches {
			ELEMENT[at0001] matches {    -- id_paciente
				value matches {
					DV_TEXT matches {*}
				}
			}
			ELEMENT[at0002] occurrences matches {0..1} matches {*}    -- nombre_completo
		}
	}

