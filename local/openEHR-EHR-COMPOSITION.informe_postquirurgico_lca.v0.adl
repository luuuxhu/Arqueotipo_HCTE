definition
	COMPOSITION[at0000] matches {    -- Informe postquirúrgico LCA
		category matches {
			DV_CODED_TEXT matches {
				defining_code matches {
					[openehr::433]
				}
			}
		}
		context matches {
			EVENT_CONTEXT matches {
				other_context matches {
					ITEM_TREE[at0001] matches {    -- Item tree
						items cardinality matches {0..*; unordered} matches {
							allow_archetype CLUSTER[at0003] occurrences matches {0..*} matches {    -- Datos paciente
								include
									archetype_id/value matches {/openEHR-EHR-CLUSTER\.datos_paciente\.v0/}
							}
							allow_archetype CLUSTER[at0005] occurrences matches {0..*} matches {    -- Episodio LCA
								include
									archetype_id/value matches {/openEHR-EHR-CLUSTER\.episodio_lca\.v0/}
							}
						}
					}
				}
			}
		}
		content cardinality matches {1..*; unordered} matches {
			SECTION[at0007] occurrences matches {0..1} matches {    -- Contexto quirúrgico
				items cardinality matches {1..*; unordered} matches {
					allow_archetype ACTION[at0009] matches {    -- Reconstruccion LCA
						include
							archetype_id/value matches {/openEHR-EHR-ACTION\.reconstruccion_lca\.v0/}
					}
				}
			}
			SECTION[at0008] occurrences matches {0..1} matches {    -- Evaluación inicial
				items cardinality matches {1..*; unordered} matches {
					allow_archetype OBSERVATION[at0010] matches {    -- Dolor inflamacion
						include
							archetype_id/value matches {/openEHR-EHR-OBSERVATION\.dolor_inflamacion\.v1/}
					}
					allow_archetype OBSERVATION[at0011] matches {    -- Rango de movimiento rodilla
						include
							archetype_id/value matches {/openEHR-EHR-OBSERVATION\.rango_de_movimiento_rodilla\.v1/}
					}
				}
			}
		}
	}

