definition
	OBSERVATION[at0000] matches {    -- Hop tests
		data matches {
			HISTORY[at0001] matches {    -- History
				events cardinality matches {1..*; unordered} matches {
					EVENT[at0002] occurrences matches {0..*} matches {    -- Any event
						data matches {
							ITEM_TREE[at0003] matches {    -- Tree
								items cardinality matches {0..*; unordered} matches {
									CLUSTER[at0011] occurrences matches {0..*} matches {    -- Resultado de prueba
										items cardinality matches {1..*; unordered} matches {
											ELEMENT[at0012] matches {    -- Tipo de prueba
												value matches {
													DV_CODED_TEXT matches {
														defining_code matches {
															[local::
															at0013,    -- Single Hop
															at0014,    -- Triple Hop
															at0015,    -- Crossover Hop
															at0016]    -- 6-meter Timed Hop
														}
													}
												}
											}
											ELEMENT[at0017] matches {    -- Resultado lado operado
												value matches {
													C_DV_QUANTITY <
														
														list = <
															["1"] = <
																units = <"cm">
																magnitude = <|0.0..500.0|>
																precision = <|1|>
															>
															["2"] = <
																units = <"s">
															>
														>
													>
												}
											}
											ELEMENT[at0018] matches {    -- Resultado lado sano
												value matches {
													C_DV_QUANTITY <
														
														list = <
															["1"] = <
																units = <"cm">
																magnitude = <|0.0..500.0|>
																precision = <|3|>
															>
															["2"] = <
																units = <"s">
															>
														>
													>
												}
											}
											ELEMENT[at0019] matches {    -- Índice de simetría LSI
												value matches {
													DV_PROPORTION matches {
														precision matches {|1|}
													}
												}
											}
										}
									}
								}
							}
						}
					}
				}
			}
		}
		protocol matches {
			ITEM_TREE[at0006] matches {*}    -- Item tree
		}
	}

