					text = <"Datos del paciente">
					description = <"Información demográfica básica del paciente (reutilizable)">
				>
				["at0001"] = <
					text = <"id_paciente">
					description = <"Identificador único del paciente">
				>
				["at0002"] = <
					text = <"nombre_completo">
					description = <"Nombre completo del paciente">
				>
			>
		>
	>
