					description = <"">
				>
				["at0029"] = <
					text = <"No apto — requiere revisión médica">
					description = <"">
				>
				["at0030"] = <
					text = <"Fecha estimada de retorno deportivo">
					description = <"Fecha aproximada en la que se prevé que el paciente pueda retomar la actividad deportiva completa.">
				>
				["at0031"] = <
					text = <"Observaciones clínicas">
					description = <"Anotaciones adicionales del profesional sobre el estado del paciente o condiciones específicas para el retorno deportivo.">
				>
