definition
	EVALUATION[at0000] matches {    -- alta_deportiva
		data matches {
			ITEM_TREE[at0001] matches {    -- Item tree
				items cardinality matches {0..*; unordered} matches {
					CLUSTER[at0002] occurrences matches {0..1} matches {    -- Criterios de alta cumplidos
						items cardinality matches {1..*; unordered} matches {
							ELEMENT[at0032] matches {    -- Fuerza muscular ≥90%
								value matches {
									DV_BOOLEAN matches {*}
								}
							}
							ELEMENT[at0033] matches {    -- Hop tests ≥85%
								value matches {
									DV_BOOLEAN matches {*}
								}
							}
							ELEMENT[at0034] matches {    -- Test de Lachman negativo
								value matches {
									DV_BOOLEAN matches {*}
								}
							}
							ELEMENT[at0035] matches {    -- Rango de movimiento completo
								value matches {
									DV_BOOLEAN matches {*}
								}
							}
							ELEMENT[at0036] matches {    -- Ausencia de inflamación
								value matches {
									DV_BOOLEAN matches {*}
								}
							}
						}
					}
					ELEMENT[at0024] occurrences matches {0..1} matches {    -- Puntuación ACL-RSI
						value matches {
							C_DV_QUANTITY <
								property = <[openehr::507]>
								list = <
									["1"] = <
										units = <"1">
										magnitude = <|0.0..100.0|>
										precision = <|0|>
									>
								>
							>
						}
					}
					ELEMENT[at0025] occurrences matches {0..1} matches {    -- Decisión de alta deportiva
						value matches {
							DV_CODED_TEXT matches {
								defining_code matches {
									[local::
									at0026,    -- Apto para retorno deportivo completo
									at0027,    -- Apto con restricciones
									at0028,    -- No apto — requiere continuar rehabilitación
									at0029]    -- No apto — requiere revisión médica
								}
							}
						}
					}
					ELEMENT[at0030] occurrences matches {0..1} matches {    -- Fecha estimada de retorno deportivo
						value matches {
							DV_DATE matches {*}
						}
					}
					ELEMENT[at0031] occurrences matches {0..1} matches {    -- Observaciones clínicas
						value matches {
							DV_TEXT matches {*}
						}
					}
				}
			}
		}
	}

ontology
	term_definitions = <
		["es"] = <
			items = <
				["at0000"] = <
					text = <"alta_deportiva">
					description = <"Criterios_Progresion">
				>
				["at0001"] = <
					text = <"Item tree">
					description = <"@ internal @">
				>
				["at0002"] = <
					text = <"Criterios de alta cumplidos">
					description = <"Conjunto de criterios objetivos que deben cumplirse simultáneamente para autorizar el retorno a la actividad deportiva.">
				>
				["at0024"] = <
					text = <"Puntuación ACL-RSI">
					description = <"Resultado del cuestionario ACL-Return to Sport after Injury que evalúa la preparación psicológica del paciente para el retorno deportivo.">
				>
				["at0025"] = <
					text = <"Decisión de alta deportiva">
					description = <"Valoración clínica final sobre la aptitud del paciente para el retorno a la actividad deportiva previa a la lesión.">
				>
				["at0026"] = <
					text = <"Apto para retorno deportivo completo">
					description = <"">
